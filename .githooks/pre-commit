#!/usr/bin/env bash
#
# Pre-commit: bump plugin versions, propagate shared files.
#
# 1. Bump versions: increments z in plugin.json for each plugin with staged changes.
# 2. Propagate shared files: copies ocd plugin framework to all non-ocd plugins.
#
# Template → deployed sync runs out-of-band in /checkpoint (auto-init script),
# not here — commits can batch without paying the force-init cost each time.
#
# Propagated files:
#   tools/environment.py                   — path resolution (canonical at project root, copied to <plugin>/tools/)
#   tools/errors.py                        — shared exception types  (canonical at project root, copied to <plugin>/tools/)
#   systems/setup/__init__.py              — facade with star imports (to systems/setup/)
#   systems/setup/__main__.py              — CLI entry point (to systems/setup/)
#   systems/setup/_metadata.py             — plugin metadata discovery (to systems/setup/)
#   systems/setup/_deployment.py           — template deployment primitives (to systems/setup/)
#   systems/setup/_enabled.py              — per-system opt-in state (to systems/setup/)
#   systems/setup/_formatting.py           — output formatting (to systems/setup/)
#   systems/setup/_system_discovery.py     — system and skill discovery (to systems/setup/)
#   systems/setup/_orchestration.py        — install/enable/disable orchestration (to systems/setup/)
#   systems/rules/_init.py                 — rules subsystem (to systems/rules/)
#   systems/conventions/_init.py           — conventions subsystem (to systems/conventions/)
#   systems/patterns/_init.py              — patterns subsystem (to systems/patterns/)
#   systems/log/_init.py                   — log subsystem (to systems/log/)
#   systems/permissions/__init__.py        — permissions facade (to systems/permissions/)
#   systems/permissions/_init.py           — permissions subsystem (to systems/permissions/)
#   systems/permissions/_operations.py     — permissions operations (to systems/permissions/)
#   hooks/install_deps.sh                  — SessionStart venv install (to hooks/)

set -euo pipefail

staged=$(git diff --cached --name-only)

# --- Bump plugin versions ---
# Each plugin with staged changes (excluding plugin.json itself) gets its
# z version incremented. Keeps marketplace reload detection working without
# requiring the agent to remember the bump.

for plugin_json in plugins/*/.claude-plugin/plugin.json; do
    plugin_dir=$(dirname "$(dirname "$plugin_json")")
    plugin_name=$(basename "$plugin_dir")

    # Skip if only plugin.json changed (avoid double-bump on amend)
    if echo "$staged" | grep -v "\.claude-plugin/plugin\.json" | grep -q "^plugins/${plugin_name}/"; then
        current=$(python3 -c "import json; print(json.load(open('${plugin_json}'))['version'])")
        new=$(python3 -c "v='${current}'.split('.'); v[-1]=str(int(v[-1])+1); print('.'.join(v))")
        python3 -c "
import json, pathlib
p = pathlib.Path('${plugin_json}')
d = json.loads(p.read_text())
d['version'] = '${new}'
p.write_text(json.dumps(d, indent=2) + '\n')
"
        # Stage to whichever index is current (the temp index during
        # partial-commit, the main index otherwise). The main-index
        # sync under partial-commit happens in the post-commit hook —
        # pre-commit can't write the main index while git holds its
        # commit-level lock.
        git add "$plugin_json"
    fi
done

# --- Propagate shared plugin files ---

# Map of canonical paths to target subdirectories within each plugin.
# Canonical sources for always-on primitives live at project-root tools/;
# setup package and per-subsystem _init.py files live under plugins/ocd/.
SHARED_FILES=(
    "tools/environment.py:tools"
    "tools/errors.py:tools"
    "plugins/ocd/systems/setup/__init__.py:systems/setup"
    "plugins/ocd/systems/setup/__main__.py:systems/setup"
    "plugins/ocd/systems/setup/_metadata.py:systems/setup"
    "plugins/ocd/systems/setup/_deployment.py:systems/setup"
    "plugins/ocd/systems/setup/_enabled.py:systems/setup"
    "plugins/ocd/systems/setup/_formatting.py:systems/setup"
    "plugins/ocd/systems/setup/_system_discovery.py:systems/setup"
    "plugins/ocd/systems/setup/_orchestration.py:systems/setup"
    "plugins/ocd/systems/rules/_init.py:systems/rules"
    "plugins/ocd/systems/conventions/_init.py:systems/conventions"
    "plugins/ocd/systems/log/_init.py:systems/log"
    "plugins/ocd/systems/permissions/__init__.py:systems/permissions"
    "plugins/ocd/systems/permissions/_init.py:systems/permissions"
    "plugins/ocd/systems/permissions/_operations.py:systems/permissions"
    "plugins/ocd/hooks/install_deps.sh:hooks"
)

staged=$(git diff --cached --name-only)

for entry in "${SHARED_FILES[@]}"; do
    canonical="${entry%%:*}"
    target_subdir="${entry##*:}"

    # Only act if the canonical file is staged
    if ! echo "$staged" | grep -qx "$canonical"; then
        continue
    fi

    filename="$(basename "$canonical")"

    # Derive the plugin that owns the canonical source, if any. Canonical
    # sources at project root (no plugins/ prefix) are owned by none — every
    # plugin receives a vendored copy. Canonical sources under plugins/<name>/
    # skip <name> so the source is never copied over itself.
    source_plugin=""
    if [[ "$canonical" == plugins/* ]]; then
        source_plugin="${canonical#plugins/}"
        source_plugin="${source_plugin%%/*}"
    fi

    # Copy to every eligible plugin that already has the target
    # subdirectory. Opt-in model: a plugin only receives a propagated file
    # once its maintainer has created the subsystem directory that holds it.
    for plugin_dir in plugins/*/; do
        plugin_name="$(basename "$plugin_dir")"
        [ -n "$source_plugin" ] && [ "$plugin_name" = "$source_plugin" ] && continue

        dest_dir="${plugin_dir}${target_subdir}"
        [ -d "$dest_dir" ] || continue

        git show ":${canonical}" > "${dest_dir}/${filename}"
        git add "${dest_dir}/${filename}"
    done
done
