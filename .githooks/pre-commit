#!/usr/bin/env bash
#
# Pre-commit: apply the in-PR plugin patch-version bump.
#
# For each plugin with staged code changes (any plugins/<name>/ file other than
# its own plugin.json), set the version to z+1 of origin/main — unless it's
# already ahead (idempotent; a manual minor/major bump is respected). The bump
# is staged into the commit, so the change and its version land together (no
# server-side push-back to a protected main — the failure that retired
# auto-bump.yml). Runs on every branch; the prior hook's deliberate "feature
# branches skip" is now safe because the /checkpoint flow recomputes against a
# freshly-fetched main at landing time, and bump-check.yml is the CI belt.
#
# Logic lives in scripts/bump-apply.py (stdlib only). The post-commit hook syncs
# the main index under partial-commit semantics. If origin/main is unavailable
# the script no-ops gracefully (the CI belt still catches a missing bump).

set -euo pipefail

python3 scripts/bump-apply.py --staged origin/main
