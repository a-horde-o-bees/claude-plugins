#!/usr/bin/env bash
#
# Pre-commit: sync templates, bump plugin versions, propagate shared files.
#
# 1. Sync templates → deployed: ensures .claude/{rules,conventions,patterns}/
#    match their plugin template sources at commit time.
# 2. Bump versions: increments z in plugin.json for each plugin with staged changes.
# 3. Propagate shared files: copies ocd plugin framework to all non-ocd plugins.
#
# Propagated files:
#   plugin/__init__.py                     — facade with star imports (to plugin/)
#   plugin/__main__.py                     — CLI entry point (to plugin/)
#   plugin/_environment.py                 — environment resolution (to plugin/)
#   plugin/_metadata.py                    — plugin metadata discovery (to plugin/)
#   plugin/_deployment.py                  — template deployment primitives (to plugin/)
#   plugin/_formatting.py                  — output formatting (to plugin/)
#   plugin/_discovery.py                   — system and skill discovery (to plugin/)
#   plugin/_orchestration.py               — install and list orchestration (to plugin/)
#   lib/rules/_init.py                     — rules subsystem (to lib/rules/)
#   lib/conventions/_init.py               — conventions subsystem (to lib/conventions/)
#   lib/patterns/_init.py                  — patterns subsystem (to lib/patterns/)
#   lib/logs/_init.py                      — logs subsystem (to lib/logs/)
#   lib/permissions/__init__.py            — permissions facade (to lib/permissions/)
#   lib/permissions/_init.py               — permissions subsystem (to lib/permissions/)
#   lib/permissions/_operations.py         — permissions operations (to lib/permissions/)

set -euo pipefail

staged=$(git diff --cached --name-only)

# --- Sync templates → deployed ---

python3 scripts/sync-templates.py >/dev/null 2>&1 || true

# --- Bump plugin versions ---
# Each plugin with staged changes (excluding plugin.json itself) gets its
# z version incremented. Keeps marketplace reload detection working without
# requiring the agent to remember the bump.

for plugin_json in plugins/*/.claude-plugin/plugin.json; do
    plugin_dir=$(dirname "$(dirname "$plugin_json")")
    plugin_name=$(basename "$plugin_dir")

    # Skip if only plugin.json changed (avoid double-bump on amend)
    if echo "$staged" | grep -v "\.claude-plugin/plugin\.json" | grep -q "^plugins/${plugin_name}/"; then
        current=$(python3 -c "import json; print(json.load(open('${plugin_json}'))['version'])")
        new=$(python3 -c "v='${current}'.split('.'); v[-1]=str(int(v[-1])+1); print('.'.join(v))")
        python3 -c "
import json, pathlib
p = pathlib.Path('${plugin_json}')
d = json.loads(p.read_text())
d['version'] = '${new}'
p.write_text(json.dumps(d, indent=2) + '\n')
"
        git add "$plugin_json"
    fi
done

# --- Propagate shared plugin files ---

# Map of canonical paths to target subdirectories within each plugin
SHARED_FILES=(
    "plugins/ocd/plugin/__init__.py:plugin"
    "plugins/ocd/plugin/__main__.py:plugin"
    "plugins/ocd/plugin/_environment.py:plugin"
    "plugins/ocd/plugin/_metadata.py:plugin"
    "plugins/ocd/plugin/_deployment.py:plugin"
    "plugins/ocd/plugin/_formatting.py:plugin"
    "plugins/ocd/plugin/_discovery.py:plugin"
    "plugins/ocd/plugin/_orchestration.py:plugin"
    "plugins/ocd/lib/rules/_init.py:lib/rules"
    "plugins/ocd/lib/conventions/_init.py:lib/conventions"
    "plugins/ocd/lib/patterns/_init.py:lib/patterns"
    "plugins/ocd/lib/logs/_init.py:lib/logs"
    "plugins/ocd/lib/permissions/__init__.py:lib/permissions"
    "plugins/ocd/lib/permissions/_init.py:lib/permissions"
    "plugins/ocd/lib/permissions/_operations.py:lib/permissions"
)

staged=$(git diff --cached --name-only)

for entry in "${SHARED_FILES[@]}"; do
    canonical="${entry%%:*}"
    target_subdir="${entry##*:}"

    # Only act if the canonical file is staged
    if ! echo "$staged" | grep -qx "$canonical"; then
        continue
    fi

    filename="$(basename "$canonical")"

    # Copy to all non-ocd plugins; create target subdirectory if missing
    for plugin_dir in plugins/*/; do
        plugin_name="$(basename "$plugin_dir")"
        [ "$plugin_name" = "ocd" ] && continue

        dest_dir="${plugin_dir}${target_subdir}"
        mkdir -p "$dest_dir"

        git show ":${canonical}" > "${dest_dir}/${filename}"
        git add "${dest_dir}/${filename}"
    done
done
