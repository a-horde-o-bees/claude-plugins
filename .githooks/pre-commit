#!/usr/bin/env bash
#
# Pre-commit: sync templates to deployed copies, propagate shared plugin files.
#
# 1. Sync templates → deployed: ensures .claude/{rules,conventions,patterns}/
#    match their plugin template sources at commit time.
# 2. Propagate shared files: copies ocd plugin framework to all non-ocd plugins.
#
# Propagated files:
#   plugin/__init__.py                     — facade with star imports (to plugin/)
#   plugin/__main__.py                     — CLI entry point (to plugin/)
#   plugin/_environment.py                 — environment resolution (to plugin/)
#   plugin/_metadata.py                    — plugin metadata discovery (to plugin/)
#   plugin/_deployment.py                  — template deployment primitives (to plugin/)
#   plugin/_formatting.py                  — output formatting (to plugin/)
#   plugin/_content.py                     — content deployment and state (to plugin/)
#   plugin/_discovery.py                   — system and skill discovery (to plugin/)
#   plugin/_permissions.py                 — permissions analysis (to plugin/)
#   plugin/_orchestration.py               — init and status orchestration (to plugin/)

set -euo pipefail

# --- Sync templates → deployed ---

python3 scripts/sync-templates.py >/dev/null 2>&1 || true

# --- Propagate shared plugin files ---

# Map of canonical paths to target subdirectories within each plugin
SHARED_FILES=(
    "plugins/ocd/plugin/__init__.py:plugin"
    "plugins/ocd/plugin/__main__.py:plugin"
    "plugins/ocd/plugin/_environment.py:plugin"
    "plugins/ocd/plugin/_metadata.py:plugin"
    "plugins/ocd/plugin/_deployment.py:plugin"
    "plugins/ocd/plugin/_formatting.py:plugin"
    "plugins/ocd/plugin/_content.py:plugin"
    "plugins/ocd/plugin/_discovery.py:plugin"
    "plugins/ocd/plugin/_permissions.py:plugin"
    "plugins/ocd/plugin/_orchestration.py:plugin"
)

staged=$(git diff --cached --name-only)

for entry in "${SHARED_FILES[@]}"; do
    canonical="${entry%%:*}"
    target_subdir="${entry##*:}"

    # Only act if the canonical file is staged
    if ! echo "$staged" | grep -qx "$canonical"; then
        continue
    fi

    filename="$(basename "$canonical")"

    # Copy to all non-ocd plugins that have the target subdirectory
    for plugin_dir in plugins/*/; do
        plugin_name="$(basename "$plugin_dir")"
        [ "$plugin_name" = "ocd" ] && continue

        dest_dir="${plugin_dir}${target_subdir}"
        [ -d "$dest_dir" ] || continue

        git show ":${canonical}" > "${dest_dir}/${filename}"
        git add "${dest_dir}/${filename}"
    done
done
