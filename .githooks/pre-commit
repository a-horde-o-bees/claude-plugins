#!/usr/bin/env bash
#
# Pre-commit: bump plugin versions, propagate canonical shared files into skills.
#
# 1. Bump versions: increments z in plugin.json for each plugin with staged changes.
# 2. Propagate canonicals: for each project-root `shared/<subfolder>/<file>`
#    that's staged, copy it into every `<plugin>/skills/<name>/<subfolder>/<file>`
#    that already exists. File-existence opt-in — a skill only receives
#    propagation once its maintainer has placed an initial copy.
#
# Architectural model: project-root `shared/` is canonical storage only, never
# imported from at runtime in distributed code. `shared/scripts/` and
# `shared/dependencies/` mirror the skill-internal layout. Each skill bundles
# its own copies (so it runs independently of any project import path) and
# this hook keeps those bundled copies byte-equal to canonical.

set -euo pipefail

staged=$(git diff --cached --name-only)

# --- Bump plugin versions ---
# Each plugin with staged changes (excluding plugin.json itself) gets its
# z version incremented on commits to main. Feature branches skip the
# bump — only commits landing on main fire dev-channel reload detection,
# and bumping on sandbox branches creates rebase conflicts at update
# time when origin/main has advanced past the branch's z value.

current_branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$current_branch" = "main" ]; then
    for plugin_json in plugins/*/.claude-plugin/plugin.json; do
        plugin_dir=$(dirname "$(dirname "$plugin_json")")
        plugin_name=$(basename "$plugin_dir")

        # Skip if only plugin.json changed (avoid double-bump on amend)
        if echo "$staged" | grep -v "\.claude-plugin/plugin\.json" | grep -q "^plugins/${plugin_name}/"; then
            current=$(python3 -c "import json; print(json.load(open('${plugin_json}'))['version'])")
            new=$(python3 -c "v='${current}'.split('.'); v[-1]=str(int(v[-1])+1); print('.'.join(v))")
            python3 -c "
import json, pathlib
p = pathlib.Path('${plugin_json}')
d = json.loads(p.read_text())
d['version'] = '${new}'
p.write_text(json.dumps(d, indent=2) + '\n')
"
            # Stage to whichever index is current (the temp index during
            # partial-commit, the main index otherwise). The main-index
            # sync under partial-commit happens in the post-commit hook —
            # pre-commit can't write the main index while git holds its
            # commit-level lock.
            git add "$plugin_json"
        fi
    done
fi

# --- Propagate canonical shared files into skills ---
#
# Every file under `shared/scripts/` (*.py) and `shared/dependencies/`
# (*.md) is a canonical whose content propagates into every
# `<plugin>/skills/<name>/<subfolder>/<file>` that already exists. The
# subfolder under `shared/` mirrors the same subfolder under each skill —
# `shared/scripts/X.py` lands in `<skill>/scripts/X.py`,
# `shared/dependencies/X.md` lands in `<skill>/dependencies/X.md`.
# File-existence opt-in: a skill only receives propagation once its
# maintainer has placed an initial copy.
#
# Glob over the canonical directories — new canonicals (added via the
# rules-skill or by promoting a project-level rule) propagate without
# needing this hook to be edited. `__init__.py` and other non-canonical
# package markers are skipped: skills' subfolders have their own package
# markers for their own modules.

shopt -s nullglob
canonicals=( shared/scripts/*.py shared/dependencies/*.md shared/assets/*.md )
shopt -u nullglob

for canonical in "${canonicals[@]}"; do
    case "$(basename "$canonical")" in
        __init__.py) continue ;;
    esac

    # Only act if the canonical was staged
    if ! echo "$staged" | grep -qx "$canonical"; then
        continue
    fi

    # Strip the `shared/` umbrella to get the relative path that mirrors
    # into each skill's own folder.
    relpath="${canonical#shared/}"

    for skill_dir in plugins/*/skills/*/; do
        target_file="${skill_dir}${relpath}"
        [ -f "$target_file" ] || continue
        git show ":${canonical}" > "$target_file"
        git add "$target_file"
    done
done
