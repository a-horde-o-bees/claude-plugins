#!/usr/bin/env bash
#
# Pre-commit: apply the plugin patch-version bump on direct-to-main commits.
#
# The version bump belongs at integration into main, never on a feature branch
# (two branches bumping the same plugin would both claim the same "next"
# version — fractured bookkeeping that collides at merge). The PR path applies
# the bump at merge time against the then-current main (see the merge driver).
# This hook covers the OTHER integration path: a commit made directly on main
# (admin bypass), where bump-check.yml (pull_request-only) can't reach. On any
# other branch it is a no-op.
#
# Logic lives in scripts/bump-apply.py (stdlib only). The post-commit hook syncs
# the main index under partial-commit semantics.

set -euo pipefail

branch=$(git rev-parse --abbrev-ref HEAD)
[ "$branch" = "main" ] || exit 0

python3 scripts/bump-apply.py --staged origin/main
