{
  "mcpServers": {
    "navigator": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.navigator"],
      "env": {
        "DB_PATH": ".claude/ocd/navigator/navigator.db"
      }
    },
    "governance": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.governance"],
      "env": {
        "GOVERNANCE_DB": ".claude/ocd/governance/governance.db"
      }
    },
    "friction": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.friction"],
      "env": {
        "FRICTION_DB": ".claude/ocd/friction/friction.db"
      }
    },
    "decisions": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.decisions"],
      "env": {
        "DECISIONS_DB": ".claude/ocd/decisions/decisions.db"
      }
    },
    "stash": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.stash"],
      "env": {
        "STASH_DB": ".claude/ocd/stash/stash.db"
      }
    },
    "log": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.log"],
      "env": {
        "LOG_DB": ".claude/ocd/log/log.db"
      }
    }
  }
}
