{
  "mcpServers": {
    "ocd-navigator": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.navigator"],
      "env": {
        "DB_PATH": ".claude/ocd/navigator/navigator.db"
      }
    },
    "ocd-friction": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.friction"],
      "env": {
        "FRICTION_DIR": ".claude/ocd/friction"
      }
    },
    "ocd-decisions": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.decisions"]
    },
    "ocd-stash": {
      "command": "${CLAUDE_PLUGIN_DATA}/venv/bin/python3",
      "args": ["${CLAUDE_PLUGIN_ROOT}/run.py", "servers.stash"]
    }
  }
}
