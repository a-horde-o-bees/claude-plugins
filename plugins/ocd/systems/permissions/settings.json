        "Bash(diff:*)",
        "Bash(mktemp:*)"
      ]
    },
    "text_processing": {
      "description": "Text search, sort, and filtering",
      "patterns": [
        "Bash(cat:*)",
        "Bash(head:*)",
        "Bash(tail:*)",
        "Bash(grep:*)",
        "Bash(sort:*)",
        "Bash(uniq:*)",
