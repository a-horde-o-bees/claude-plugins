#!/bin/bash
# ocd-run — PATH-accessible entry to the plugin's Python dispatcher.
#
# Claude Code adds each installed plugin's bin/ directory to PATH, so this
# script becomes `ocd-run` in any shell Claude Code runs. It resolves the
# plugin venv's python3 (which has weasyprint, mcp, etc. installed) and
# execs run.py with whatever arguments were passed. Agents can call:
#
#     ocd-run systems.navigator scan .
#     ocd-run systems.pdf --src foo.md
#
# without needing to know CLAUDE_PLUGIN_ROOT, CLAUDE_PLUGIN_DATA, or where
# the venv actually lives.
#
# Naming convention: every plugin ships a `<plugin>-run` binary in its
# bin/ directory. The object_action shape (ocd + run) matches the
# project's MCP tool convention (paths_get, governance_match, ...) and
# follows CLI precedent like gitlab-runner and docker-compose. The
# suffix also makes the name collision-resistant — `which ocd-run` is
# almost certainly unique.
#
# Venv discovery order:
#   1. $CLAUDE_PLUGIN_DATA/venv/bin/python3 (running inside a hook/MCP context)
#   2. Persisted path at $plugin_root/.venv-python (written by install_deps.sh)
#   3. Derived from Claude Code's cache/data naming (marketplace install)
#   4. Derived from <plugin>-inline data dir (--plugin-dir dev mode)
#   5. $plugin_root/venv/bin/python3 (self-contained dev checkout)
#   6. System python3 (fallback; works for stdlib-only systems)

set -euo pipefail

script_real="$(readlink -f "$0")"
plugin_root="$(dirname "$(dirname "$script_real")")"

# === Self-update on plugin upgrade ===
# When the plugin's source pyproject.toml differs from the cached manifest in
# the data dir, run install_deps.sh synchronously so the venv reflects the
# current source. flock serializes concurrent invocations; the lock-protected
# block re-checks drift to avoid double-install when another process was
# already past the diff but mid-install. Skipped silently when the plugin
# doesn't ship install_deps.sh.
#
# MCP servers spawn from .mcp.json directly (not through ocd-run), so they
# pick up venv changes only on session restart. Mid-session MCP refresh
# remains a known limitation per logs/decision/ocd-run-self-update.md.

if [[ -x "$plugin_root/hooks/install_deps.sh" ]]; then
    if [[ -n "${CLAUDE_PLUGIN_DATA:-}" ]]; then
        _data_dir="$CLAUDE_PLUGIN_DATA"
    elif [[ "$plugin_root" == */plugins/cache/*/* ]]; then
        _version_dir="$plugin_root"
        _plugin_dir="$(dirname "$_version_dir")"
        _author_dir="$(dirname "$_plugin_dir")"
        _cache_dir="$(dirname "$_author_dir")"
        _plugins_dir="$(dirname "$_cache_dir")"
        _plugin_name="$(basename "$_plugin_dir")"
        _author_name="$(basename "$_author_dir")"
        _data_dir="$_plugins_dir/data/${_plugin_name}-${_author_name}"
    else
        _plugin_basename="$(basename "$plugin_root")"
        _data_dir="$HOME/.claude/plugins/data/${_plugin_basename}-inline"
    fi

    _source_manifest="$plugin_root/pyproject.toml"
    _cached_manifest="$_data_dir/pyproject.toml"

    if [[ -f "$_source_manifest" ]]; then
        if [[ ! -f "$_cached_manifest" ]] || ! diff -q "$_source_manifest" "$_cached_manifest" >/dev/null 2>&1; then
            mkdir -p "$_data_dir"
            (
                flock 9
                if [[ ! -f "$_cached_manifest" ]] || ! diff -q "$_source_manifest" "$_cached_manifest" >/dev/null 2>&1; then
                    CLAUDE_PLUGIN_ROOT="$plugin_root" CLAUDE_PLUGIN_DATA="$_data_dir" "$plugin_root/hooks/install_deps.sh"
                fi
            ) 9>"$_data_dir/.install-lock"
        fi
    fi
fi
# === End self-update ===

_venv_python=""

# 1. Env var set by Claude Code during hook/MCP invocation
if [[ -n "${CLAUDE_PLUGIN_DATA:-}" && -x "$CLAUDE_PLUGIN_DATA/venv/bin/python3" ]]; then
    _venv_python="$CLAUDE_PLUGIN_DATA/venv/bin/python3"
fi

# 2. Persisted path written by install_deps.sh
if [[ -z "$_venv_python" && -f "$plugin_root/.venv-python" ]]; then
    candidate="$(cat "$plugin_root/.venv-python")"
    if [[ -x "$candidate" ]]; then
        _venv_python="$candidate"
    fi
fi

# 3. Derive from Claude Code's installed layout
#    cache path: ~/.claude/plugins/cache/<author>/<plugin>/<version>/
#    data path:  ~/.claude/plugins/data/<plugin>-<author>/venv/
if [[ -z "$_venv_python" && "$plugin_root" == */plugins/cache/*/* ]]; then
    version_dir="$plugin_root"
    plugin_dir="$(dirname "$version_dir")"
    author_dir="$(dirname "$plugin_dir")"
    cache_dir="$(dirname "$author_dir")"
    plugins_dir="$(dirname "$cache_dir")"
    plugin_name="$(basename "$plugin_dir")"
    author_name="$(basename "$author_dir")"
    candidate="$plugins_dir/data/${plugin_name}-${author_name}/venv/bin/python3"
    if [[ -x "$candidate" ]]; then
        _venv_python="$candidate"
    fi
fi

# 4. --plugin-dir mode: Claude Code writes into <plugin>-inline data dir
#    when a plugin is loaded via --plugin-dir rather than marketplace.
#    CLAUDE_PLUGIN_DATA is set for hooks/MCP but not for agent Bash tool
#    subprocesses, so the wrapper reconstructs the path from HOME.
if [[ -z "$_venv_python" ]]; then
    plugin_name="$(basename "$plugin_root")"
    candidate="$HOME/.claude/plugins/data/${plugin_name}-inline/venv/bin/python3"
    if [[ -x "$candidate" ]]; then
        _venv_python="$candidate"
    fi
fi

# 5. Self-contained dev checkout: venv inside plugin root
if [[ -z "$_venv_python" && -x "$plugin_root/venv/bin/python3" ]]; then
    _venv_python="$plugin_root/venv/bin/python3"
fi

# 6. System fallback
if [[ -z "$_venv_python" ]]; then
    _venv_python="$(command -v python3 || true)"
fi

if [[ -z "$_venv_python" ]]; then
    echo "ocd: no python3 found" >&2
    exit 127
fi

exec "$_venv_python" "$plugin_root/run.py" "$@"
