{
  "permissions": {
    "allow": [
      "Bash(./scripts/run-plugin.sh:*)",
      "Bash(bash scripts/test.sh:*)",
      "mcp__plugin_blueprint_blueprint-research__*",
      "mcp__plugin_ocd_navigator__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/guard-templates.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
