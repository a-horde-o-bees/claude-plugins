{
  "permissions": {
    "allow": [
      "Bash(./scripts/run-plugin.sh:*)",
      "mcp__plugin_blueprint_blueprint-research__*",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "WebFetch",
      "WebSearch",
      "LSP",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(tree:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(ln:*)",
      "Bash(touch:*)",
      "Bash(stat:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(mktemp:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tee:*)",
      "Bash(less:*)",
      "Bash(xargs:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(awk:*)",
      "Bash(git:*)",
      "Bash(python3:*)",
      "Bash(.venv/bin/*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(uv lock:*)",
      "Bash(uv pip:*)",
      "Bash(uvx:*)",
      "Bash(pip:*)",
      "Bash(pip3:*)",
      "Bash(pyright:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(claude mcp:*)",
      "Bash(claude plugins:*)",
      "Bash(.claude/*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(which:*)",
      "Bash(env:*)",
      "Bash(echo:*)",
      "Bash(test:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/guard-templates.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
